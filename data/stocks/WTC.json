  "hypotheses": {
    "N1": {
      "label": "Franchise Intact",
      "description": "CW organic growth reaccelerates to 15%+; e2open integration unlocks cross-sell; margins recover to 50%+ by FY28",
      "plain_english": "WiseTech's core CargoWise platform is unimpaired by the e2open acquisition. Organic growth reaccelerates as the 9% 1H26 figure proves transitional (implementation delays, not structural loss). The restructuring delivers on its margin targets and e2open's supply chain customers begin converting to CargoWise.",
      "what_to_watch": "CW organic revenue growth in 2H26 and FY27. If it returns above 12%, the franchise-intact thesis strengthens materially. Also watch e2open customer migration announcements.",
      "upside": "Full re-rating toward pre-crisis multiples. CW at 15%+ growth with 50% margins on a US$1.5B+ revenue base supports A$81 (25x EV/EBITDA FY28).",
      "risk_plain": "This scenario requires everything to go right: growth reaccelerates, restructuring delivers, and the e2open integration does not distract management from CargoWise product development.",
      "survival_score": 0.05,
      "status": "VERY_LOW",
      "weighted_inconsistency": 3.5,
      "last_updated": "2026-03-17T07:32:15.599Z"
    },
    "N2": {
      "label": "Restructuring Recovery",
      "description": "CW growth stays 9-12% but restructuring lifts blended margins from 38% to 45%+; valuation re-rates on earnings delivery",
      "plain_english": "CargoWise organic growth does not fully reaccelerate but holds in the high single digits. The restructuring programme is the real driver: US$125M in annualised savings lift blended EBITDA margins from 38% toward 48-50% by FY28. The stock re-rates on demonstrated earnings improvement rather than top-line growth.",
      "what_to_watch": "Quarterly margin progression through FY26-FY27. If blended EBITDA margins reach 42%+ by 2H26, the restructuring thesis is tracking. Also monitor headcount reductions and e2open platform consolidation milestones.",
      "upside": "Margin expansion to 48% on US$1.4B revenue supports A$65 (20x EV/EBITDA FY28). Still material upside from A$47.",
      "risk_plain": "The restructuring may prove more costly or slower than announced. If savings are front-loaded but margin improvement plateaus at 42-43%, the re-rating case weakens.",
      "survival_score": 0.05,
      "status": "VERY_LOW",
      "weighted_inconsistency": 2.2,
      "last_updated": "2026-03-17T07:32:15.599Z"
    },
    "N3": {
      "label": "Integration Tax",
      "description": "e2open integration absorbs management bandwidth; CW organic growth stays below 10%; margins stuck at 38-42%",
      "plain_english": "The e2open acquisition turns out to be a value-destructive distraction. Management attention shifts from CargoWise product innovation to integration firefighting. The 9% CW organic growth in 1H26 was not transitional; it was the beginning of a structural slowdown as enterprise customers delay expansion while WiseTech digests a major acquisition.",
      "what_to_watch": "CW organic growth below 9% in 2H26, restructuring delays or cost overruns, key CW product roadmap delays, and any increase in enterprise customer churn above 3%.",
      "upside": null,
      "risk_plain": "Integration-distracted management is the classic acquirer trap. If CW organic growth stays below 10% for three consecutive halves, the franchise premium erodes permanently.",
      "survival_score": 0.45,
      "status": "MODERATE",
      "weighted_inconsistency": 2.5,
      "last_updated": "2026-03-17T21:27:00.655Z"
    },
    "N4": {
      "label": "Reflexive Unravelling",
      "description": "Covenant breach or near-miss triggers forced equity raise; customer confidence collapses; stock enters reflexive decline",
      "plain_english": "The e2open debt load (US$945M net debt, 2.78x leverage) meets a covenant test failure or near-miss in July 2026. Lenders tighten terms, forcing a dilutive equity raise. Enterprise customers accelerate evaluation of alternatives. The stock enters a reflexive cycle where falling price impairs the company's ability to retain talent and win contracts.",
      "what_to_watch": "July 2026 covenant test (3.5x leverage limit). Net debt trajectory through 2H26. Any credit rating action or lender communication. Employee attrition data.",
      "upside": null,
      "risk_plain": "This is the tail risk scenario. It requires the combination of covenant pressure, customer defection, and talent loss. Probability is low (12%) but the outcome is severe.",
      "survival_score": 0.45,
      "status": "MODERATE",
      "weighted_inconsistency": 4.8,
      "last_updated": "2026-03-17T21:27:00.655Z"
    }
  },
